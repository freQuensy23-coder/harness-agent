server:
  host: 127.0.0.1
  port: 8080

database:
  path: ./data/harness.sqlite3

llm:
  base_url: https://openrouter.ai/api/v1
  api_key: replace-me
  model: z-ai/glm-5v-turbo

telegram:
  enabled: false
  bot_token: null

runtime:
  docker:
    image: python:3.14-slim
    container_prefix: harness
    network: null
    memory: 1g
    cpus: "1"

scheduler:
  poll_seconds: 5

mcp:
  servers: []
  # Global MCP servers exposed to every user. The user cannot edit or disable
  # them from their workspace. Each entry runs inside the user's container via
  # the same stdio transport as user-defined servers at /workspace/mcp/*.yaml.
  # On name conflict, the global entry wins.
  #
  # Example:
  # servers:
  #   - name: local
  #     command: ["python", "/workspace/mcp_server.py"]
  #     cwd: /workspace
